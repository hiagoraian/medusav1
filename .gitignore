# Dependências
node_modules/
package-lock.json

# Variáveis de ambiente (cada máquina tem a sua)
.env

# Mídia de campanhas (cada máquina faz upload)
uploads/
temp_media/

# Listas de contatos (cada máquina tem as suas)
listas/*
!listas/.gitkeep

# Frases de aquecimento (cada máquina tem as suas)
textAquecimento.txt

# Config de notificação local (JID do grupo varia por máquina)
notification_config.json
whitelist_notificacao.txt

# Relatórios de disparo (gerados localmente)
reports/

# Mídia de aquecimento (só a estrutura vai pro git)
warmup_media/imagens/*
warmup_media/audios/*
!warmup_media/imagens/.gitkeep
!warmup_media/audios/.gitkeep

# Resquícios da v1
.wwebjs_cache/
.wwebjs_auth/
orquestrador.sqlite

# Claude Code
.claude/

# Sistema operacional
.DS_Store
Thumbs.db
