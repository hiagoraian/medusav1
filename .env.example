# Evolution API
EVOLUTION_URL=http://localhost:8081
EVOLUTION_API_KEY=medusa-evolution-secret-key

# PostgreSQL
POSTGRES_PASSWORD=medusa_strong_password
DATABASE_URL=postgresql://medusa:medusa_strong_password@localhost:5432/medusa

# RabbitMQ
RABBITMQ_PASSWORD=medusa_rabbitmq_password
RABBITMQ_URL=amqp://medusa:medusa_rabbitmq_password@localhost:5672

# App
PORT=3000

# ADB — Serials dos celulares ZTE (diferente em cada máquina, não commitado)
# Rodar "adb devices" para ver os serials conectados
ZTE_1_SERIAL=XXXXXXXX   # Zaps WA-01 a WA-12 (grupos A/B/C)
ZTE_2_SERIAL=XXXXXXXX   # Zaps WA-13 a WA-24 (grupos A/B/C)
ZTE_3_SERIAL=XXXXXXXX   # Zaps WA-25 a WA-36 (grupos A/B/C)
ZTE_4_SERIAL=XXXXXXXX   # Zaps WA-37 a WA-48 (grupos A/B/C)
